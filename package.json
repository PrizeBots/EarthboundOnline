{
  "name": "eb_online",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch vite.config.ts --watch server --ignore \"server/*.test.js\" --ext ts,js --exec \"npx vite --port 4444\"",
    "build": "vite build",
    "start": "node server/index.js",
    "typecheck": "tsc --noEmit",
    "check:server": "node --check server/gameHost.js && node --check server/npcSim.js && node --check server/shops.js && node --check server/index.js",
    "test": "node server/gameHost.test.js",
    "verify": "npm run typecheck && npm run check:server && npm test",
    "extract": "python tools/convert_all.py"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@smwcentral/spc-player": "^2.0.2",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  }
}
