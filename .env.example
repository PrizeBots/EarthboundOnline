# 199X — server environment.
# Copy to .env (gitignored) for local use, or set these in your host's dashboard.

# Persistence backend. If set, the server uses Supabase/Postgres for accounts,
# sessions, and character saves. If UNSET, it falls back to local SQLite
# (data/eb.db) — fine for dev. See SUPABASE_SETUP.md.
# Use the Supabase "Connection pooler" URI (recommended for a web service).
# DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres

# HTTP/WS port (defaults to 3333 if unset).
# PORT=3333
