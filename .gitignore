# Dependencies
node_modules/

# ROM file (copyrighted — do not commit)
EarthBound.sfc

# CoilSnake decompiled project (extracted from ROM)
eb_project/

# Extraction output (intermediate)
extracted/

# ROM-derived game assets (atlases, sprites, map/collision JSON extracted from
# the ROM). NEVER commit — players supply their own ROM and assets are extracted
# client-side (PokeMMO model; see CLAUDE.md). Kept on disk locally for fast dev,
# but untracked so they never enter the repo or a production build.
public/assets/

# Build output
dist/

# Local persistence DB (accounts/sessions/saves — never commit player data)
/data/
*.db
*.db-wal
*.db-shm

# Python
__pycache__/
*.pyc

# Test renders
public/test_onett.png
public/test_render.png

# Debug/scratch renders from tools (ROM-derived pixels — never commit, per
# CLAUDE.md ROM policy). Verify scripts also emit screenshots; keep them out.
tools/*.png
tools/*.jpg
tools/_*
*.screenshot.png

# Blender
*.blend
*.blend1

